# Copy to .env and fill in real values. Never commit .env.

# Required: shared secret all MCP clients must present as Bearer token.
# Generate with: openssl rand -hex 32
BRIDGE_API_KEY=

# Bind address. 127.0.0.1 = localhost only (recommended for security; expose
# externally via CF Tunnel rather than binding 0.0.0.0).
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=18800
